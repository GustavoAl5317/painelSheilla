generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  logo               String?
  primaryColor       String           @default("#1a56db")
  email              String
  phone              String?
  plan               PlanType         @default(STARTER)
  planExpiresAt      DateTime?
  businessHoursStart String           @default("08:00")
  businessHoursEnd   String           @default("18:00")
  businessDays       String           @default("1,2,3,4,5")
  defaultGreeting    String?
  defaultSignature   String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  aiConfig           AIConfig?
  clients            Client[]
  clientCaseCards    ClientCaseCard[]
  conversations      Conversation[]
  crmBoards          CrmBoard[]
  deadlines          Deadline[]
  promptTemplates    PromptTemplate[]
  integrations       Integration[]
  kanbanStages       KanbanStage[]
  leads              Lead[]
  notifications      Notification[]
  credentials        OrgCredential[]
  processes          Process[]
  tasks              Task[]
  appointments       Appointment[]
  users              User[]
}

model User {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  password          String
  role              UserRole       @default(MEMBER)
  avatar            String?
  isActive          Boolean        @default(true)
  organizationId    String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  assignedLeads        Lead[]            @relation("AssignedLeads")
  notifications        Notification[]
  assignedProcesses    Process[]         @relation("AssignedProcesses")
  assignedTasks        Task[]            @relation("AssignedTasks")
  createdTasks         Task[]            @relation("CreatedTasks")
  createdAppointments  Appointment[]     @relation("CreatedAppointments")
  crmActivities        CrmCardActivity[]
  organization         Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model KanbanStage {
  id             String       @id @default(cuid())
  name           String
  slug           String
  order          Int
  color          String       @default("#6b7280")
  isDefault      Boolean      @default(false)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads          Lead[]

  @@unique([organizationId, slug])
}

model Lead {
  id                  String         @id @default(cuid())
  name                String
  phone               String?
  email               String?
  source              LeadSource     @default(WHATSAPP)
  legalArea           String?
  caseSummary         String?
  status              LeadStatus     @default(ACTIVE)
  organizationId      String
  stageId             String?
  assignedToId        String?
  aiQualified         Boolean        @default(false)
  aiSummary           String?
  aiScore             Int?
  convertedToClientAt DateTime?
  clientId            String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  conversations       Conversation[]
  assignedTo          User?          @relation("AssignedLeads", fields: [assignedToId], references: [id])
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stage               KanbanStage?   @relation(fields: [stageId], references: [id])
  notifications       Notification[]
  tasks               Task[]
  appointments        Appointment[]
}

model Client {
  id                     String          @id @default(cuid())
  name                   String
  phone                  String?
  email                  String?
  cpf                    String?
  rg                     String?
  address                String?
  notes                  String?
  tramitacaoCustomerId   Int?
  tramitacaoCustomerUuid String?
  tramitacaoSyncStatus   String?
  tramitacaoSyncedAt     DateTime?
  trelloCardId           String?
  trelloCardUrl          String?
  organizationId         String
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  processNumber          String?
  organization           Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  caseCard               ClientCaseCard?
  conversations          Conversation[]
  crmCards               CrmCard[]
  processes              Process[]
  tasks                  Task[]
  appointments           Appointment[]

  @@index([organizationId])
}

model ClientCaseCard {
  id             String          @id @default(cuid())
  organizationId String
  clientId       String          @unique
  processId      String?
  lastNotifiedAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sendUpdates    Boolean         @default(true)
  entries        CaseCardEntry[]
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  process        Process?        @relation(fields: [processId], references: [id])

  @@index([organizationId])
  @@index([processId])
}

model CaseCardEntry {
  id              String              @id @default(cuid())
  cardId          String
  source          CaseCardEntrySource
  content         String
  shareWithClient Boolean             @default(true)
  metadata        Json?
  createdAt       DateTime            @default(now())
  card            ClientCaseCard      @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
}

model Conversation {
  id             String             @id @default(cuid())
  phoneNumber    String
  status         ConversationStatus @default(OPEN)
  aiEnabled      Boolean            @default(true)
  organizationId String
  leadId         String?
  clientId       String?
  lastMessageAt          DateTime?
  operatorLastMessageAt  DateTime?
  unreadCount            Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  isBlocked      Boolean            @default(false)
  client         Client?            @relation(fields: [clientId], references: [id])
  lead           Lead?              @relation(fields: [leadId], references: [id])
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@unique([organizationId, phoneNumber])
  @@index([organizationId])
}

model Message {
  id             String           @id @default(cuid())
  content        String
  type           MessageType      @default(TEXT)
  direction      MessageDirection
  status         MessageStatus    @default(SENT)
  conversationId String
  externalId     String?
  mediaUrl       String?
  isAI           Boolean          @default(false)
  createdAt      DateTime         @default(now())
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Process {
  id               String           @id @default(cuid())
  number           String?
  title            String?
  court            String?
  legalArea        String?
  status           ProcessStatus    @default(ACTIVE)
  observations     String?
  organizationId   String
  clientId         String?
  assignedToId     String?
  nextHearing      DateTime?
  lastMovement     String?
  lastMovementAt   DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  lastDjenSearchAt DateTime?
  caseCards        ClientCaseCard[]
  crmCards         CrmCard[]
  deadlines        Deadline[]
  assignedTo       User?            @relation("AssignedProcesses", fields: [assignedToId], references: [id])
  client           Client?          @relation(fields: [clientId], references: [id])
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks            Task[]
  appointments     Appointment[]

  @@index([organizationId])
  @@index([clientId])
}

model Deadline {
  id             String         @id @default(cuid())
  title          String
  description    String?
  dueDate        DateTime
  status         DeadlineStatus @default(PENDING)
  alertSent      Boolean        @default(false)
  organizationId String
  processId      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  process        Process?       @relation(fields: [processId], references: [id], onDelete: Cascade)
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  organizationId String
  assignedToId   String?
  createdById    String?
  leadId         String?
  clientId       String?
  processId      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  assignedTo     User?        @relation("AssignedTasks", fields: [assignedToId], references: [id])
  client         Client?      @relation(fields: [clientId], references: [id])
  createdBy      User?        @relation("CreatedTasks", fields: [createdById], references: [id])
  lead           Lead?        @relation(fields: [leadId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  process        Process?     @relation(fields: [processId], references: [id])
}

model Appointment {
  id              String            @id @default(cuid())
  title           String
  description     String?
  date            DateTime
  durationMinutes Int               @default(60)
  status          AppointmentStatus @default(SCHEDULED)
  notifyClient    Boolean           @default(true)
  reminderSent    Boolean           @default(false)
  organizationId  String
  clientId        String?
  leadId          String?
  guestName       String?
  processId       String?
  createdById     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client?           @relation(fields: [clientId], references: [id])
  lead            Lead?             @relation(fields: [leadId], references: [id])
  process         Process?          @relation(fields: [processId], references: [id])
  createdBy       User?             @relation("CreatedAppointments", fields: [createdById], references: [id])

  @@index([organizationId])
  @@index([clientId])
  @@index([leadId])
}

model Notification {
  id             String           @id @default(cuid())
  type           NotificationType
  title          String
  message        String
  read           Boolean          @default(false)
  organizationId String
  userId         String?
  leadId         String?
  metadata       Json?
  createdAt      DateTime         @default(now())
  lead           Lead?            @relation(fields: [leadId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?            @relation(fields: [userId], references: [id])
}

model AIConfig {
  id                      String       @id @default(cuid())
  provider                AIProvider   @default(OPENAI)
  useGlobalKey            Boolean      @default(true)
  apiKey                  String?
  model                   String       @default("gpt-4o-mini")
  systemPrompt            String?
  greeting                String?
  qualificationQuestions  Json?
  transferToHumanKeywords String[]     @default([])
  isActive                Boolean      @default(true)
  organizationId          String       @unique
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  blockedNumbers          Json?        @default("[]")
  operatorKeyword         String?
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Integration {
  id             String          @id @default(cuid())
  type           IntegrationType
  isActive       Boolean         @default(false)
  config         Json?
  organizationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
}

model OrgCredential {
  id             String       @id @default(cuid())
  key            String
  value          String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
}

model PlanLimit {
  id                String   @id @default(cuid())
  plan              PlanType @unique
  maxUsers          Int
  maxLeadsPerMonth  Int
  maxAIMessages     Int
  allowIntegrations Boolean  @default(false)
  allowCustomAIKey  Boolean  @default(false)
  allowReports      Boolean  @default(false)
  allowAlerts       Boolean  @default(true)
  priceMonthly      Float
  priceYearly       Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum PlanType {
  STARTER
  PRO
  PREMIUM
  ENTERPRISE
}

enum LeadSource {
  WHATSAPP
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  EMAIL
  PHONE
  OTHER
}

enum LeadStatus {
  ACTIVE
  CONVERTED
  LOST
  ARCHIVED
}

enum ConversationStatus {
  OPEN
  WAITING_RESPONSE
  IN_PROGRESS
  RESOLVED
  TRANSFERRED_TO_HUMAN
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  LOCATION
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum ProcessStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
  CONCLUDED
}

enum DeadlineStatus {
  PENDING
  COMPLETED
  OVERDUE
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CaseCardEntrySource {
  COMMENT
  DJEN
  PJE
  SYSTEM
}

enum NotificationType {
  DEADLINE_APPROACHING
  DEADLINE_OVERDUE
  NEW_LEAD
  LEAD_STALLED
  NEW_MESSAGE
  TASK_DUE
  PROCESS_UPDATE
  CLIENT_NO_RESPONSE
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  CUSTOM
}

// ─── Prompt Templates ─────────────────────────────────────────────────────────

model PromptTemplate {
  id             String       @id @default(cuid())
  name           String
  description    String?
  content        String
  isDefault      Boolean      @default(false)
  isSystem       Boolean      @default(false)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ─── CRM ──────────────────────────────────────────────────────────────────────

model CrmBoard {
  id             String      @id @default(cuid())
  name           String
  slug           String
  color          String      @default("#6b7280")
  order          Int
  organizationId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cards          CrmCard[]

  @@unique([organizationId, slug])
}

model CrmCard {
  id             String            @id @default(cuid())
  title          String
  description    String?
  boardId        String
  organizationId String
  processId      String?
  clientId       String?
  order          Int               @default(0)
  dueDate        DateTime?
  priority       CrmPriority       @default(NONE)
  tags           String[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  board          CrmBoard          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  process        Process?          @relation(fields: [processId], references: [id], onDelete: SetNull)
  client         Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  activities     CrmCardActivity[]

  @@index([boardId])
  @@index([processId])
  @@index([clientId])
}

model CrmCardActivity {
  id        String   @id @default(cuid())
  cardId    String
  userId    String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  card      CrmCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([cardId, createdAt])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum CrmPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IntegrationType {
  TRELLO
  BITRIX
  HUBSPOT
  ZAPIER
  ZAPI
  EVOLUTION_API
  PJE
  TRAMITACAO_INTELIGENTE
}
